[Unit]
Description=Renew journal-gatewayd TLS certificate from step-ca
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
Group=root
Environment="STEPPATH={{ journal_gateway_step_dir }}"

# Uses the existing cert to authenticate (no password). On renewal, restart the
# socket-activated gatewayd so it re-reads the new certificate.
ExecStart=/usr/bin/step ca renew --daemon \
  --exec "systemctl try-restart systemd-journal-gatewayd.service" \
  {{ journal_gateway_cert_path }} \
  {{ journal_gateway_key_path }}

Restart=on-failure
RestartSec=30

[Install]
WantedBy=multi-user.target
