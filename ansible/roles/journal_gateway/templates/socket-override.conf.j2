# Managed by Ansible (journal_gateway role).
# Clear the packaged ListenStream (all interfaces) then bind narrowly.
[Socket]
ListenStream=
{% if journal_gateway_tls_enabled %}
# TLS mode: gatewayd serves plain HTTP on loopback; ghostunnel terminates mTLS.
ListenStream=127.0.0.1:{{ journal_gateway_backend_port }}
{% else %}
# Plain mode (cloud): bind the WireGuard site address directly.
ListenStream={{ journal_gateway_bind_address }}:{{ journal_gateway_port }}
FreeBind=true
{% endif %}
