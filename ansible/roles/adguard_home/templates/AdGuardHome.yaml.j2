#jinja2: trim_blocks: True, lstrip_blocks: True
# Managed by ansible role adguard_home. Answers (filters, rewrites, upstreams)
# come from config/adguard-settings.json — the SAME source the nix LXC resolvers
# use — so this offsite resolver never drifts. Only bind address + admin user are
# overridden per platform. AdGuard runs on the host network and binds ONLY the
# WireGuard site-edge IP (never 0.0.0.0, never loopback — systemd-resolved owns
# 127.0.0.53:53). Fabric-only exposure enforced by the site_wireguard nft rules.
{{ (lookup('file', adguard_settings_json_path) | from_json
    | combine({
        'dns': {'bind_hosts': [adguard_wg_ip]},
        'http': {'address': adguard_wg_ip ~ ':3000'},
        'users': [{'name': adguard_web_user, 'password': adguard_web_password_hash}],
      }, recursive=True)) | to_nice_yaml(indent=2) }}
