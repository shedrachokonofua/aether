# Managed by Ansible (gigahub_exporter role). Do not edit by hand.
[server]
listen = "{{ gigahub_exporter_listen }}"
state_directory = "{{ gigahub_exporter_state_dir }}"

[device]
address = "{{ gigahub_exporter_device_address }}"
{% if gigahub_observations_enabled | default(false) %}
instance = "gigahub"
{% endif %}
scheme = "{{ gigahub_exporter_scheme }}"
{% if gigahub_exporter_scheme == "https" %}
tls_accept_invalid_certs = {{ gigahub_exporter_tls_accept_invalid_certs | lower }}
{% endif %}

[auth]
method = "sha512"
username_file = "{{ gigahub_exporter_creds_dir }}/username"
password_file = "{{ gigahub_exporter_creds_dir }}/password"

{% if gigahub_observations_enabled | default(false) %}
[observations]
enabled = true
directory = "{{ gigahub_exporter_state_dir }}/observations"
{% endif %}
[collectors.device_info]
enabled = true

[collectors.optical]
enabled = true

[collectors.gpon]
enabled = true

[collectors.ethernet]
enabled = true
handoff_interface = "{{ gigahub_exporter_handoff_interface }}"

[collectors.hosts]
enabled = true

[collectors.selfview]
enabled = true
