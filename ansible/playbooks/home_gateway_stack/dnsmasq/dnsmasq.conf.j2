# Split DNS for admin and peer tailnets with access to the home gateway.
# Authoritative-only: responds to configured domains, NXDOMAIN for all else.
#
# Admin tailnet split DNS and peer tailnets both query this listener:
#   home.shdr.ch    -> {{ tf_outputs.home_gateway_tailscale_ip.value }}
#   k8s.seven30.xyz -> {{ tf_outputs.home_gateway_tailscale_ip.value }}

listen-address={{ tf_outputs.home_gateway_tailscale_ip.value }}
bind-dynamic
port=53

no-resolv
no-hosts

# Shared routes -> home gateway Tailscale interface.
# Caddy binds only these routes to the Tailscale listener.
address=/grafana.home.shdr.ch/{{ tf_outputs.home_gateway_tailscale_ip.value }}
address=/bao.home.shdr.ch/{{ tf_outputs.home_gateway_tailscale_ip.value }}
address=/gitlab.home.shdr.ch/{{ tf_outputs.home_gateway_tailscale_ip.value }}
address=/registry.gitlab.home.shdr.ch/{{ tf_outputs.home_gateway_tailscale_ip.value }}
address=/pages.gitlab.home.shdr.ch/{{ tf_outputs.home_gateway_tailscale_ip.value }}

# Admin-only home routes -> home gateway LAN listener.
# Shared-device recipients cannot reach subnet destinations by ACL, and the
# Tailscale Caddy listener returns 403 for routes not explicitly bound there.
address=/home.shdr.ch/{{ vm.home_gateway_stack.ip }}

# k8s.seven30.xyz → home gateway (vcluster API via Caddy)
address=/k8s.seven30.xyz/{{ tf_outputs.home_gateway_tailscale_ip.value }}

# mars.seven30.xyz → home gateway (LAN-only vcluster route via Caddy)
address=/mars.seven30.xyz/{{ tf_outputs.home_gateway_tailscale_ip.value }}

log-queries
log-facility=-
