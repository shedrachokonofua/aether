# Split DNS for admin tailnet devices.
# Authoritative-only: responds to configured domains, NXDOMAIN for all else.
#
# Admin devices query the admin-only Tailscale identity:
#   home.shdr.ch    -> {{ tf_outputs.home_admin_gateway_tailscale_ip.value }}
#   k8s.seven30.xyz -> {{ tf_outputs.home_admin_gateway_tailscale_ip.value }}

listen-address={{ tf_outputs.home_admin_gateway_tailscale_ip.value }}
bind-dynamic
port=53

no-resolv
no-hosts

# Admin devices resolve home services to the LAN Caddy listener, then reach it
# through subnet routes advertised only by tag:admin-gateway.
address=/home.shdr.ch/{{ vm.home_gateway_stack.ip }}
address=/k8s.seven30.xyz/{{ vm.home_gateway_stack.ip }}
address=/mars.seven30.xyz/{{ vm.home_gateway_stack.ip }}

log-queries
log-facility=-
