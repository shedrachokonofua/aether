model_list:
  # llama-swap (K8s)
  - model_name: "aether/qwen3.5-27b"
    litellm_params:
      model: "openai/qwen3.5-27b"
      litellm_credential_name: llama_swap_credential
  - model_name: "aether/qwen3.5-27b:code"
    litellm_params:
      model: "openai/qwen3.5-27b:code"
      litellm_credential_name: llama_swap_credential
  - model_name: "aether/qwen3.5-27b:think"
    litellm_params:
      model: "openai/qwen3.5-27b:think"
      litellm_credential_name: llama_swap_credential
  - model_name: "aether/qwen3.5-9b"
    litellm_params:
      model: "openai/qwen3.5-9b"
      litellm_credential_name: llama_swap_credential

  # OpenAI models
  - model_name: "openai/gpt-5.4"
    litellm_params:
      model: "openai/gpt-5.4"
      litellm_credential_name: openai_credential
  - model_name: "openai/gpt-5.4-mini"
    litellm_params:
      model: "openai/gpt-5.4-mini"
      litellm_credential_name: openai_credential
  - model_name: "openai/gpt-5.4-nano"
    litellm_params:
      model: "openai/gpt-5.4-nano"
      litellm_credential_name: openai_credential

  # Anthropic models
  - model_name: "anthropic/claude-opus-4.6"
    litellm_params:
      model: "anthropic/claude-opus-4-6"
      litellm_credential_name: anthropic_credential
  - model_name: "anthropic/claude-sonnet-4.6"
    litellm_params:
      model: "anthropic/claude-sonnet-4-6"
      litellm_credential_name: anthropic_credential

  # Speaches STT/TTS (K8s)
  - model_name: "aether/whisper-large-v3"
    litellm_params:
      model: "openai/Systran/faster-whisper-large-v3"
      litellm_credential_name: speaches_credential
  - model_name: "aether/distil-whisper-large-v3"
    litellm_params:
      model: "openai/Systran/faster-distil-whisper-large-v3"
      litellm_credential_name: speaches_credential
  - model_name: "aether/kokoro-tts"
    litellm_params:
      model: "openai/speaches-ai/Kokoro-82M-v1.0-ONNX"
      litellm_credential_name: speaches_credential

  # Reranker + Embeddings via llama-swap (K8s)
  - model_name: "aether/bge-reranker-v2-m3"
    litellm_params:
      model: "openai/bge-reranker-v2-m3"
      litellm_credential_name: llama_swap_credential
  - model_name: "aether/qwen3-embedding:4b"
    litellm_params:
      model: "openai/qwen3-embedding-4b"
      litellm_credential_name: llama_swap_credential

  # OpenRouter models
  - model_name: "openrouter/grok-4"
    litellm_params:
      model: "openai/x-ai/grok-4"
      litellm_credential_name: openrouter_credential
  - model_name: "openrouter/gemini-3.1-pro-preview"
    litellm_params:
      model: "openai/google/gemini-3.1-pro-preview"
      litellm_credential_name: openrouter_credential
  - model_name: "openrouter/gemini-3-flash-preview"
    litellm_params:
      model: "openai/google/gemini-3-flash-preview"
      litellm_credential_name: openrouter_credential
  - model_name: "openrouter/moonshotai-kimi-k2.5"
    litellm_params:
      model: "openai/moonshotai/kimi-k2.5"
      litellm_credential_name: openrouter_credential
  - model_name: "openrouter/stepfun-step-3.5-flash"
    litellm_params:
      model: "openai/stepfun/step-3.5-flash:free"
      litellm_credential_name: openrouter_credential
  - model_name: "openrouter/arcee-ai-trinity-large-preview"
    litellm_params:
      model: "openai/arcee-ai/trinity-large-preview:free"
      litellm_credential_name: openrouter_credential

credential_list:
  - credential_name: llama_swap_credential
    credential_values:
      api_base: https://llama-swap.apps.home.shdr.ch/v1
      api_key: none
    credential_info:
      description: "llama-swap on K8s (via Gateway)"
  - credential_name: speaches_credential
    credential_values:
      api_base: https://speaches.apps.home.shdr.ch/v1
      api_key: none
    credential_info:
      description: "Speaches STT/TTS on K8s (via Gateway)"
  - credential_name: openai_credential
    credential_values:
      api_key: os.environ/OPENAI_API_KEY
    credential_info:
      description: "OpenAI"
  - credential_name: anthropic_credential
    credential_values:
      api_key: os.environ/ANTHROPIC_API_KEY
    credential_info:
      description: "Anthropic"
  - credential_name: openrouter_credential
    credential_values:
      api_base: https://openrouter.ai/api/v1
      api_key: os.environ/OPENROUTER_API_KEY
    credential_info:
      description: "OpenRouter"

litellm_settings:
  drop_params: true
  turn_off_message_logging: false
  set_verbose: true
  json_logs: true
  request_timeout: 600

general_settings:
  store_prompts_in_spend_logs: true

mcp_servers:
  time:
    url: "http://localhost:8003/mcp"
  firecrawl:
    url: "https://mcp.firecrawl.home.shdr.ch/mcp"
  alpha_vantage:
    url: "https://mcp.alphavantage.co/mcp?apikey={{ secrets.alphavantage_api_key }}"
  # coingecko:
  #   url: "http://localhost:8002/"
  finviz:
    url: "http://localhost:8000/mcp"
  microsandbox:
    url: "http://host.containers.internal:{{ vm.ai_tool_stack.ports.microsandbox }}/mcp"