<clickhouse>
  <!-- Keep role/profile constraint merging explicit across image upgrades. -->
  <access_control_improvements>
    <settings_constraints_replace_previous>true</settings_constraints_replace_previous>
  </access_control_improvements>

  <!-- Keep ClickHouse's own diagnostic tables from competing with IDS/log storage. -->
  <logger>
    <level>information</level>
  </logger>

  <text_log>
    <level>warning</level>
    <ttl>event_date + INTERVAL 7 DAY DELETE</ttl>
  </text_log>

  <!-- CH-internal CPU profiling traces; only for deep-debugging ClickHouse itself. Disabled. -->
  <trace_log remove="1"/>

  <part_log>
    <ttl>event_date + INTERVAL 7 DAY DELETE</ttl>
  </part_log>

  <query_log>
    <ttl>event_date + INTERVAL 14 DAY DELETE</ttl>
  </query_log>

  <query_views_log>
    <ttl>event_date + INTERVAL 7 DAY DELETE</ttl>
  </query_views_log>

  <metric_log>
    <collect_interval_milliseconds>10000</collect_interval_milliseconds>
    <ttl>event_date + INTERVAL 7 DAY DELETE</ttl>
  </metric_log>

  <asynchronous_metric_log>
    <collect_interval_milliseconds>10000</collect_interval_milliseconds>
    <ttl>event_date + INTERVAL 7 DAY DELETE</ttl>
  </asynchronous_metric_log>

  <query_metric_log remove="1"/>

  <background_schedule_pool_log remove="1"/>

  <processors_profile_log remove="1"/>

  <asynchronous_insert_log>
    <ttl>event_date + INTERVAL 7 DAY DELETE</ttl>
  </asynchronous_insert_log>

  <error_log>
    <ttl>event_date + INTERVAL 30 DAY DELETE</ttl>
  </error_log>
</clickhouse>
