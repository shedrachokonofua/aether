global:
  scrape_interval: 30s # was 15s; no dashboard/alert uses a sub-2m rate window (verified), so 30s is numerically identical -> halves ingest on proxmox/ceph/node/blackbox jobs. Per-job overrides remain (smart 60s).
  evaluation_interval: 15s

rule_files:
  - "/etc/prometheus/rules/*.yml"

scrape_configs:
  - job_name: "prometheus"
    static_configs:
      - targets: ["localhost:9090"]

  - job_name: "otel-collector"
    static_configs:
      - targets: ["otel_collector:8888"]

  - job_name: "otel-metrics"
    scrape_interval: 30s # source pushes at 30s; 15s global double-scraped ~277k series (pure waste)
    scrape_timeout: 25s # 277k-series exposition scrapes in ~6s; default 10s timeout flapped under load -> whole job (incl. monitoring-stack hostmetrics) dropped out. 25s (<30s interval) gives headroom.
    static_configs:
      - targets: ["otel_collector:8889"]

  # Physical Proxmox hosts - Node Exporter
  - job_name: "proxmox-hosts-node"
    static_configs:
      - targets:
          - "192.168.2.201:9100" # Niobe
          - "192.168.2.202:9100" # Trinity
          - "192.168.2.203:9100" # Oracle
          - "192.168.2.204:9100" # Smith
          - "192.168.2.205:9100" # Neo
        labels:
          instance_type: "proxmox_host"

  # Physical Proxmox hosts - SMART Exporter
  - job_name: "proxmox-hosts-smart"
    scrape_interval: 60s # Less frequent for disk health
    static_configs:
      - targets:
          - "192.168.2.201:9633" # Niobe
          - "192.168.2.202:9633" # Trinity
          - "192.168.2.203:9633" # Oracle
          - "192.168.2.204:9633" # Smith
          - "192.168.2.205:9633" # Neo
        labels:
          instance_type: "proxmox_host"

  # Proxmox cluster via API - scrape each host for complete cluster view
  - job_name: "proxmox-cluster"
    static_configs:
      - targets:
          - 192.168.2.201 # Niobe
          - 192.168.2.202 # Trinity
          - 192.168.2.203 # Oracle
          - 192.168.2.204 # Smith
          - 192.168.2.205 # Neo
    metrics_path: /pve
    params:
      module: [default]
      cluster: ["1"]
      node: ["1"]
    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [__param_target]
        target_label: instance
      - target_label: __address__
        replacement: localhost:9221 # PVE exporter in monitoring stack

  # Proxmox Backup Server
  - job_name: "proxmox-backup"
    static_configs:
      - targets: ["localhost:10019"]
        labels:
          instance_type: "pbs"

  # Ceph cluster - standalone ceph-exporter daemon (one per host, port 9926).
  # Avoids the mgr prometheus module, which crashes under Python 3.13 on
  # Ceph 19.2/20.2. Deploy with: task configure:ceph-exporter
  - job_name: "ceph"
    honor_labels: true
    static_configs:
      - targets:
          - "192.168.2.202:9926" # Trinity
          - "192.168.2.204:9926" # Smith
          - "192.168.2.205:9926" # Neo
        labels:
          instance_type: "ceph"

  # blackbox-exporter — TLS handshake probes, exports
  # `probe_ssl_earliest_cert_expiry` so the Grafana cert-expiry alert can fire
  # before a cert silently rolls past NotAfter (see Apr 2026 OpenBao incident).
  - job_name: "blackbox-tls"
    metrics_path: /probe
    params:
      module: [tls_connect]
    static_configs:
      - targets:
          - "10.0.2.9:8200"     # OpenBao internal TLS
          - "192.168.2.235:443" # step-ca
          - "10.0.2.2:443"      # home gateway Caddy
    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [__param_target]
        target_label: instance
      - target_label: __address__
        replacement: localhost:9115

{% if tf_outputs.synthetic_probe_targets.value | default([]) | length > 0 %}
  # blackbox-exporter — HTTP availability probes for namespace-contract apps.
  # Targets are rendered from tf_outputs.synthetic_probe_targets (tofu output).
  - job_name: "blackbox-http-apps"
    metrics_path: /probe
    params:
      module: [http_2xx]
    static_configs:
{% for target in tf_outputs.synthetic_probe_targets.value | default([]) %}
      - targets:
          - "{{ target.url }}"
        labels:
          probe_namespace: "{{ target.namespace }}"
          probe_exposure: "{{ target.exposure }}"
          probe_criticality: "{{ target.criticality }}"
          probe_hostname: "{{ target.hostname }}"
{% endfor %}
    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [__param_target]
        target_label: instance
      - target_label: __address__
        replacement: localhost:9115
{% endif %}
