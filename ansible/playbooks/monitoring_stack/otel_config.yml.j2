receivers:
  otlp:
    protocols:
      grpc:
        endpoint: "0.0.0.0:4317"
      http:
        endpoint: "0.0.0.0:4318"

processors:
  memory_limiter:
    check_interval: 5s
    # 4096/896 (was 2048/512): the 2026-07-11 clickhouse/metrics incident — collector
    # heap hit 2374MiB and the limiter refused ALL ingest. Soft refusal is now
    # limit-spike = 3200MiB, deliberately ABOVE the container GOMEMLIMIT (3GiB) so the
    # Go GC fights heap growth before the limiter ever drops data. VM has 16GiB;
    # worst-case stack (prom 5G + otel ~4G + CH 3G) still fits.
    limit_mib: 4096
    spike_limit_mib: 896

  batch:
    timeout: 10s
    send_batch_size: 2048
    send_batch_max_size: 4096

  # Archive-only batching: ClickHouse wants FEW, LARGE inserts (benchmarked
  # 2026-07-11 on live CH 26.6.1.1193: 50k-row blocks at 180-310k rows/s = ~38x
  # headroom over the 7.4k pts/s stream). The 2048-point hot-path batch produced
  # 5 tiny per-type inserts each and drowned the exporter (queue pinned, CPU churn).
  batch/archive:
    timeout: 30s
    send_batch_size: 50000
    send_batch_max_size: 100000

  # Selectively promote essential resource attributes to metric labels
  # This avoids the cardinality explosion from full resource_to_telemetry_conversion
  transform/metrics:
    metric_statements:
      - context: datapoint
        statements:
          # Host/service identification
          - set(attributes["host_name"], resource.attributes["host.name"]) where resource.attributes["host.name"] != nil
          - set(attributes["service_name"], resource.attributes["service.name"]) where resource.attributes["service.name"] != nil
          - set(attributes["exported_job"], resource.attributes["service.name"]) where resource.attributes["service.name"] != nil
          # Container attributes for per-container breakdown
          - set(attributes["container_name"], resource.attributes["container.name"]) where resource.attributes["container.name"] != nil
          - set(attributes["container_image_name"], resource.attributes["container.image.name"]) where resource.attributes["container.image.name"] != nil
          - set(attributes["container_id"], resource.attributes["container.id"]) where resource.attributes["container.id"] != nil
          # Tenant scoping
          - set(attributes["service_namespace"], resource.attributes["service.namespace"]) where resource.attributes["service.namespace"] != nil

  # Journal-forwarder logs arrive with service.name = the systemd unit and the
  # host in host.name. Rewrite service.name to the host so these sources match
  # the fleet convention (VM agents set service.name = hostname); the unit stays
  # in the journald_unit_name attribute. Scoped by instance_type, which only the
  # forwarder sets, so zeek/suricata/VM/k8s logs are untouched.
  transform/journal_forwarder_identity:
    error_mode: ignore
    log_statements:
      - context: resource
        statements:
          - set(attributes["service.name"], attributes["host.name"]) where attributes["instance_type"] != nil and attributes["host.name"] != nil

connectors:
  # Route logs based on source - single decision point
  routing/logs:
    default_pipelines: [logs/loki]
    error_mode: ignore
    table:
      - context: resource
        condition: attributes["log.source"] == "zeek"
        pipelines: [logs/clickhouse/zeek]
      - context: resource
        condition: attributes["log.source"] == "suricata"
        pipelines: [logs/clickhouse/suricata]

  # Route traces by tenant for Tempo multi-tenancy
  routing/traces:
    default_pipelines: [traces/default]
    error_mode: ignore
    table:
{% for tenant in tenants %}
      - context: resource
        condition: attributes["service.namespace"] == "{{ tenant.name }}"
        pipelines: [traces/{{ tenant.name }}]
{% endfor %}

exporters:
  prometheus:
    endpoint: "0.0.0.0:8889"
    send_timestamps: true
    # 2m (was 5m): dead pods' series linger in the :8889 exposition metric_expiration-long, and
    # Prometheus scrapes+parses every one every 30s (was 433k samples vs 205k active). 2m = 4x the
    # 30s push interval, so no flap; halves the churn-driven serialize(otel)+parse(prom) cost.
    metric_expiration: 2m
    resource_to_telemetry_conversion:
      enabled: false
    add_metric_suffixes: false

  otlphttp/loki:
    endpoint: http://localhost:3100/otlp

  otlp/tempo:
    endpoint: "localhost:24317"
    tls:
      insecure: true
    headers:
      X-Scope-OrgID: aether

{% for tenant in tenants %}
  otlp/tempo-{{ tenant.name }}:
    endpoint: "localhost:24317"
    tls:
      insecure: true
    headers:
      X-Scope-OrgID: "{{ tenant.name }}"
{% endfor %}

  clickhouse/zeek:
    endpoint: tcp://localhost:9000
    username: aether
    password: "{{ secrets.clickhouse.password }}"
    database: zeek
    async_insert: true
    # Ack only after async buffer flush so sync MVs have materialized typed rows.
    connection_params:
      wait_for_async_insert: "1"
    compress: lz4
    create_schema: false
    logs_table_name: ingest
    timeout: 10s
    retry_on_failure:
      enabled: true
      initial_interval: 5s
      max_interval: 30s
      max_elapsed_time: 300s

  clickhouse/suricata:
    endpoint: tcp://localhost:9000
    username: aether
    password: "{{ secrets.clickhouse.password }}"
    database: suricata
    async_insert: true
    compress: lz4
    create_schema: false
    logs_table_name: ingest
    timeout: 10s
    retry_on_failure:
      enabled: true
      initial_interval: 5s
      max_interval: 30s
      max_elapsed_time: 300s

  # Long-term metrics archive: 365d TTL in ClickHouse alongside the 30d Prometheus
  # hot path. Schema is REPO-OWNED (clickhouse/metrics-schema.sql, applied via the
  # init dir / reconcile) — create_schema stays false so the alpha exporter can
  # never mutate production schema. TTL lives in the DDL.
  clickhouse/metrics:
    endpoint: tcp://localhost:9000
    username: aether
    password: "{{ secrets.clickhouse.password }}"
    database: metrics
    async_insert: true
    compress: lz4
    create_schema: false
    timeout: 30s
    # Bounded queue: if ClickHouse inserts slow down, archive batches DROP (queue full)
    # instead of backpressuring the shared pipeline — the hot path is sacred, the
    # archive is best-effort. Short retry window for the same reason.
    sending_queue:
      enabled: true
      num_consumers: 2
      # 10 batches x ~50k points ~= 500k points bounded (~200-400MB worst case).
      queue_size: 10
    retry_on_failure:
      enabled: true
      initial_interval: 5s
      max_interval: 15s
      max_elapsed_time: 60s

service:
  telemetry:
    logs:
      level: warn
  pipelines:
    # Hot path: untouched by the archive — separate pipeline below.
    metrics:
      receivers: [otlp]
      processors: [memory_limiter, transform/metrics, batch]
      exporters: [prometheus]

    # Archive path (best-effort by construction): own large-batch processor so CH
    # gets few, huge inserts; bounded queue drops before backpressure. History of
    # the 2026-07-11 incidents + redesign rationale: telemetry-archive.md.
    # NO transform/metrics here: it's a heavy per-datapoint OTTL pass whose only job
    # is promoting resource attrs to datapoint attrs so PROMETHEUS sees labels. The
    # CH exporter reads ResourceAttributes into its own column directly, so the
    # transform is pure waste on this path (ran twice on the full stream = the +15%
    # CPU regression at settle). Dropping it is cheaper AND more correct for CH.
    metrics/archive:
      receivers: [otlp]
      processors: [memory_limiter, batch/archive]
      exporters: [clickhouse/metrics]

    # Ingest logs and route based on source
    logs:
      receivers: [otlp]
      processors: [memory_limiter, transform/journal_forwarder_identity, batch]
      exporters: [routing/logs]

    # Zeek logs -> ClickHouse
    logs/clickhouse/zeek:
      receivers: [routing/logs]
      exporters: [clickhouse/zeek]

    # Suricata logs -> ClickHouse
    logs/clickhouse/suricata:
      receivers: [routing/logs]
      exporters: [clickhouse/suricata]

    # All other logs -> Loki (default)
    logs/loki:
      receivers: [routing/logs]
      exporters: [otlphttp/loki]

    traces:
      receivers: [otlp]
      processors: [memory_limiter, batch]
      exporters: [routing/traces]

    traces/default:
      receivers: [routing/traces]
      exporters: [otlp/tempo]

{% for tenant in tenants %}
    traces/{{ tenant.name }}:
      receivers: [routing/traces]
      exporters: [otlp/tempo-{{ tenant.name }}]
{% endfor %}
