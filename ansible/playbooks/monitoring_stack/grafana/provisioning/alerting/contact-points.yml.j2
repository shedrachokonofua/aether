apiVersion: 1

contactPoints:
  - orgId: 1
    name: apprise-standard
    receivers:
      - uid: apprise-standard
        type: webhook
        settings:
          url: "https://apprise.home.shdr.ch/notify/aether?tags=standard&:message=body"
          httpMethod: POST
        disableResolveMessage: false

  - orgId: 1
    name: apprise-critical
    receivers:
      - uid: apprise-critical
        type: webhook
        settings:
          url: "https://apprise.home.shdr.ch/notify/aether?tags=critical&:message=body"
          httpMethod: POST
        disableResolveMessage: false
      # Inquest: parallel investigation path (issue + Holmes). Ack must stay fast.
      # URL path key is the Kestra webhook trigger secret (SOPS inquest.webhook_key).
      - uid: inquest-webhook
        type: webhook
        settings:
          url: "https://kestra.home.shdr.ch/api/v1/main/executions/webhook/aether.inquest/alert-intake/{{ secrets.inquest.webhook_key }}"
          httpMethod: POST
        disableResolveMessage: false

  - orgId: 1
    name: apprise-digest
    receivers:
      - uid: apprise-digest
        type: webhook
        settings:
          url: "https://apprise.home.shdr.ch/notify/aether?tags=quiet&:message=body"
          httpMethod: POST
        disableResolveMessage: false

  - orgId: 1
    name: apprise-security
    receivers:
      - uid: apprise-security
        type: webhook
        settings:
          url: "https://apprise.home.shdr.ch/notify/aether?tags=security&:message=body"
          httpMethod: POST
        disableResolveMessage: false

  - orgId: 1
    name: kuma-deadman
    receivers:
      - uid: kuma-deadman
        type: webhook
        settings:
          url: "https://status.shdr.ch/api/push/{{ secrets.uptime_kuma_deadman_push_token }}?status=up&msg=OK"
          httpMethod: POST
        disableResolveMessage: true
