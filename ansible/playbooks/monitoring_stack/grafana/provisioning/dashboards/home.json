    {
      "type": "row",
      "title": "Is everything OK?",
      "id": 1,
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      }
    },
    {
      "type": "stat",
      "title": "Targets Up %",
      "id": 2,
      "description": "Central Prometheus's own scrape targets reporting up (node, PVE, Ceph, PBS, blackbox, OTel endpoint, self). Excludes k8s metrics re-exported through the OTel collector (exported_job=*) whose count churns with pod lifecycle \u2014 see the Kubernetes dashboard for those. Not the Fleet/osquery server.",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          },
          "expr": "100*count(up{exported_job=\"\"}==1)/count(up{exported_job=\"\"})",
          "refId": "A",
          "instant": true,
          "range": false
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 95
              },
              {
                "color": "green",
                "value": 99
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value",
        "justifyMode": "center",
        "wideLayout": true
      }
    },
