    {
      "type": "timeseries",
      "title": "App availability \u2014 instant vs rolling 24h",
      "id": 33,
      "description": "Minute-by-minute fleet probe success shows active outages; rolling 24h matches the App Avail 24h stat and shows historical drag.",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 32
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          },
          "expr": "100*avg(probe_success{job=\"blackbox-http-apps\"})",
          "refId": "A",
          "instant": false,
          "range": true,
          "legendFormat": "instant availability"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          },
          "expr": "100*avg(avg_over_time(probe_success{job=\"blackbox-http-apps\"}[24h]))",
          "refId": "B",
          "instant": false,
          "range": true,
          "legendFormat": "rolling 24h"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 95,
          "max": 100,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 99
              },
              {
                "color": "green",
                "value": 99.9
              }
            ]
          },
          "custom": {
            "fillOpacity": 12,
            "showPoints": "never",
            "lineWidth": 2,
            "stacking": {
              "mode": "none"
            },
            "axisPlacement": "auto",
            "axisLabel": "availability %"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "instant availability"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "green"
                }
              },
              {
                "id": "custom.lineWidth",
                "value": 2
              },
              {
                "id": "custom.fillOpacity",
                "value": 8
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "rolling 24h"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "orange"
                }
              },
              {
                "id": "custom.lineWidth",
                "value": 2
              },
              {
                "id": "custom.fillOpacity",
                "value": 0
              },
              {
                "id": "custom.lineStyle",
                "value": {
                  "fill": "dash",
                  "dash": [
                    10,
                    10
                  ]
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": [
            "min",
            "mean",
            "lastNotNull"
          ]
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
