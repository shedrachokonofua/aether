    },
    {
      "type": "stat",
      "title": "Unique IPs",
      "id": 4,
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
          "rawSql": "SELECT uniqExact(ip) AS value FROM network.mac_ip_history FINAL",
          "refId": "A",
          "format": 1
        }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value_and_name"
      }
    },
    {
      "type": "stat",
      "title": "MACs on multiple IPs",
      "id": 5,
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
          "rawSql": "SELECT count() AS value FROM (SELECT mac FROM network.mac_ip_history FINAL GROUP BY mac HAVING uniqExact(ip) > 1)",
          "refId": "A",
          "format": 1
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name"
      }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 6,
      "panels": [],
      "title": "Historical mappings",
      "type": "row"
    },
    {
      "type": "table",
      "title": "MAC ↔ IP history",
      "id": 7,
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 6 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
          "rawSql": "SELECT mac, ip, source_type, hostname, first_seen, last_seen FROM network.mac_ip_history WHERE first_seen <= $__toTime AND last_seen >= $__fromTime ORDER BY last_seen DESC LIMIT 500",
          "refId": "A",
          "format": 1
        }
      ],
      "options": { "showHeader": true },
      "fieldConfig": { "defaults": {}, "overrides": [] }
    },
    {
      "type": "table",
      "title": "MACs seen on multiple IPs",
      "id": 8,
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 19 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
          "rawSql": "SELECT mac, uniqExact(ip) AS ip_count, arrayStringConcat(arraySort(groupArrayDistinct(ip)), ', ') AS ips FROM (SELECT mac, ip FROM network.mac_ip_history WHERE first_seen <= $__toTime AND last_seen >= $__fromTime GROUP BY mac, ip) GROUP BY mac HAVING uniqExact(ip) > 1 ORDER BY ip_count DESC LIMIT 100",
          "refId": "A",
          "format": 1
        }
      ],
      "options": { "showHeader": true },
      "fieldConfig": { "defaults": {}, "overrides": [] }
    }
  ],
  "refresh": "1m",
  "schemaVersion": 39,
  "tags": ["network", "mac", "ip", "clickhouse"],
  "templating": { "list": [] },
  "time": { "from": "now-7d", "to": "now" },
  "timezone": "browser",
  "title": "Network Address History",
  "uid": "network-address-history",
  "version": 1
