          "rawSql": "SELECT coalesce(finished_at, started_at) AS time, toString(run_id) AS run_id, profile, status, target_count, probe_count, coverage_ratio, error_code FROM estate_scan.scan_runs FINAL ORDER BY time DESC LIMIT 50",
