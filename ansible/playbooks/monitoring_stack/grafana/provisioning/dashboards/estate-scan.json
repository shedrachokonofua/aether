      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
          "rawSql": "SELECT replaceOne(a.stable_identity, 'ipv4:', '') AS ip, s.port, s.transport, s.product, s.unexpected, s.last_seen_at AS time FROM estate_scan.services AS s INNER JOIN estate_scan.assets AS a ON s.asset_id = a.asset_id WHERE s.run_id = (SELECT run_id FROM estate_scan.scan_runs FINAL WHERE status = 'succeeded' ORDER BY coalesce(finished_at, started_at) DESC LIMIT 1) ORDER BY ip, s.port LIMIT 200",
          "refId": "A",
          "format": 1
