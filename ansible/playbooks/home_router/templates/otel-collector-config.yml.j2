# OpenTelemetry Collector Configuration for VyOS Router
# Adapted for container deployment on VyOS

receivers:
  otlp:
    protocols:
      grpc:
        endpoint: "0.0.0.0:4317"
      http:
        endpoint: "0.0.0.0:4318"

  # VyOS syslog/file-based logs (non-Suricata)
  filelog:
    storage: file_storage/filelog_cursor_storage
    include:
      - /var/log/messages
      - /var/log/auth.log
      - /var/log/vyatta/*.log
      - /var/log/frr/*.log
    include_file_path: true
    include_file_name: true

  # Suricata EVE JSON logs - separate receiver for tagging
  filelog/suricata:
    storage: file_storage/filelog_cursor_storage
    include:
      - /var/log/suricata/eve.json
    include_file_path: true
    include_file_name: true
    operators:
      # Parse Suricata EVE JSON - json_parser extracts nested objects as JSON strings
      # ClickHouse MVs use JSONExtract functions to access nested fields
      - type: json_parser
        timestamp:
          parse_from: attributes.timestamp
          layout: '%Y-%m-%dT%H:%M:%S.%f%z'
        on_error: send

  # Sealed exporter records are parsed once, checkpointed persistently, then
  # deleted only after the OTLP exporter accepts them for delivery.
  filelog/vyos_observations:
    include:
      - /var/lib/vyos-exporter/observations/*.ndjson
    exclude:
      - /var/lib/vyos-exporter/observations/quarantine/*
      - /var/lib/vyos-exporter/observations/*.tmp
    storage: file_storage/vyos_observation_cursor
    start_at: beginning
    delete_after_read: true
    retry_on_failure:
      enabled: true
      max_elapsed_time: 0
    operators:
      - type: json_parser
        parse_from: body
        parse_to: attributes
        timestamp:
          parse_from: attributes.timestamp
          layout: '%Y-%m-%dT%H:%M:%S.%LZ'
      - type: add
        field: attributes["log.source"]
        value: vyos_observations
    max_log_size: 1MiB

  hostmetrics:
    collection_interval: {{ vyos_otel_host_metrics_interval | default('15s') }}
    initial_delay: 1s
    root_path: /hostfs
    scrapers:
      cpu:
      disk:
      load:
      memory:
      network:
      processes:
      process:
      system:

  podman_stats:
    endpoint: unix:///run/podman/podman.sock
    collection_interval: {{ vyos_podman_metrics_collection_interval | default('15s') }}
    initial_delay: {{ vyos_podman_metrics_initial_delay | default('1s') }}
    timeout: 5s

  prometheus/vyos_exporter:
    config:
      scrape_configs:
        - job_name: vyos-exporter
          static_configs:
            - targets: ["127.0.0.1:9612"]

processors:
  batch:
    send_batch_size: 1000
    timeout: 10s

  # Larger batches for high-volume Suricata logs
  batch/suricata:
    send_batch_size: 5000
    timeout: 5s

  resource:
    attributes:
      - key: host.name
        value: "{{ inventory_hostname }}"
        action: insert
      - key: service.name
        value: "{{ inventory_hostname }}"
        action: insert
      - key: os.type
        value: "VyOS"
        action: insert
      - key: device.type
        value: "router"
        action: insert

  # Tag Suricata logs for ClickHouse routing at monitoring stack
  resource/suricata:
    attributes:
      - key: host.name
        value: "{{ inventory_hostname }}"
        action: insert
      - key: service.name
        value: "{{ inventory_hostname }}"
        action: insert
      - key: log.source
        value: "suricata"
        action: insert

extensions:
  file_storage/filelog_cursor_storage:
    directory: /var/lib/otelcol/storage
  file_storage/vyos_observation_cursor:
    directory: /var/lib/vyos-exporter/otel-storage
    timeout: 1s
    compaction:
      # compaction.directory is a SEPARATE setting from directory; its default
      # (/var/lib/otelcol/file_storage) fails validation inside this container.
      directory: /var/lib/vyos-exporter/otel-storage
      on_start: true
      on_rebound: true
  health_check:
    endpoint: "0.0.0.0:13133"

exporters:
  otlphttp:
    endpoint: http://{{ vm.monitoring_stack.ip }}:{{ vm.monitoring_stack.ports.otel_http }}
    retry_on_failure:
      enabled: true
      initial_interval: 5s
      max_interval: 300s
    sending_queue:
      enabled: true
      num_consumers: 10
      queue_size: 10000
      storage: file_storage/vyos_observation_cursor

service:
  # Only log warnings/errors - info level logs file discovery spam
  telemetry:
    logs:
      level: warn
  extensions: [file_storage/filelog_cursor_storage, file_storage/vyos_observation_cursor, health_check]
  pipelines:
    metrics:
      receivers: [otlp, hostmetrics, podman_stats, prometheus/vyos_exporter]
      processors: [batch, resource]
      exporters: [otlphttp]
    # General logs (syslog, auth, etc.) -> Loki
    logs:
      receivers: [otlp, filelog]
      processors: [batch, resource]
      exporters: [otlphttp]
    # Suricata logs -> ClickHouse (via monitoring stack routing)
    logs/suricata:
      receivers: [filelog/suricata]
      processors: [batch/suricata, resource/suricata]
      exporters: [otlphttp]
    # Sealed NDJSON observations are already fully structured; do not mutate
    # the parsed attributes before central ClickHouse routing.
    logs/vyos_observations:
      receivers: [filelog/vyos_observations]
      exporters: [otlphttp]
    traces:
      receivers: [otlp]
      processors: [batch, resource]
      exporters: [otlphttp]

