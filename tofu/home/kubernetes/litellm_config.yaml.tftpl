model_list:
  # llama-swap (K8s) — AFFiNE Copilot streams via /v1/responses; bridge to chat/completions.
  - model_name: "aether/qwen3.6-27b"
    litellm_params:
      model: "openai/qwen3.6-27b"
      litellm_credential_name: llama_swap_credential
      use_chat_completions_api: true
  - model_name: "aether/qwen3.6-27b:code"
    litellm_params:
      model: "openai/qwen3.6-27b:code"
      litellm_credential_name: llama_swap_credential
      use_chat_completions_api: true
  - model_name: "aether/qwen3.6-27b:think"
    litellm_params:
      model: "openai/qwen3.6-27b:think"
      litellm_credential_name: llama_swap_credential
      use_chat_completions_api: true
  - model_name: "aether/qwen3.6-35b-a3b"
    litellm_params:
      model: "openai/qwen3.6-35b-a3b"
      litellm_credential_name: llama_swap_credential
      use_chat_completions_api: true
  - model_name: "aether/qwen3.6-35b-a3b:code"
    litellm_params:
      model: "openai/qwen3.6-35b-a3b:code"
      litellm_credential_name: llama_swap_credential
      use_chat_completions_api: true
  - model_name: "aether/qwen3.6-35b-a3b:think"
    litellm_params:
      model: "openai/qwen3.6-35b-a3b:think"
      litellm_credential_name: llama_swap_credential
      use_chat_completions_api: true
  - model_name: "aether/qwen3.5-9b"
    litellm_params:
      model: "openai/qwen3.5-9b"
      litellm_credential_name: llama_swap_credential
      use_chat_completions_api: true
  - model_name: "aether/qwen3.5-9b:think"
    litellm_params:
      model: "openai/qwen3.5-9b:think"
      litellm_credential_name: llama_swap_credential
      use_chat_completions_api: true
  - model_name: "aether/gemma-4-31b"
    litellm_params:
      model: "openai/gemma-4-31b"
      litellm_credential_name: llama_swap_credential
      use_chat_completions_api: true
  - model_name: "aether/gemma-4-31b:think"
    litellm_params:
      model: "openai/gemma-4-31b:think"
      litellm_credential_name: llama_swap_credential
      use_chat_completions_api: true
  - model_name: "aether/gemma-4-26b-a4b"
    litellm_params:
      model: "openai/gemma-4-26b-a4b"
      litellm_credential_name: llama_swap_credential
      use_chat_completions_api: true
  - model_name: "aether/gemma-4-26b-a4b:think"
    litellm_params:
      model: "openai/gemma-4-26b-a4b:think"
      litellm_credential_name: llama_swap_credential
      use_chat_completions_api: true

  # Ollama Cloud models
  - model_name: "ollama-cloud/kimi-k2.6"
    litellm_params:
      model: "ollama_chat/kimi-k2.6"
      litellm_credential_name: ollama_cloud_credential
  - model_name: "ollama-cloud/glm-5.2"
    litellm_params:
      model: "ollama_chat/glm-5.2"
      litellm_credential_name: ollama_cloud_credential
  - model_name: "ollama-cloud/deepseek-v4-pro:cloud"
    litellm_params:
      model: "ollama_chat/deepseek-v4-pro:cloud"
      litellm_credential_name: ollama_cloud_credential
  - model_name: "ollama-cloud/deepseek-v4-flash:cloud"
    litellm_params:
      model: "ollama_chat/deepseek-v4-flash:cloud"
      litellm_credential_name: ollama_cloud_credential
  - model_name: "ollama-cloud/gemini-3-flash-preview"
    litellm_params:
      model: "ollama_chat/gemini-3-flash-preview"
      litellm_credential_name: ollama_cloud_credential
  - model_name: "ollama-cloud/minimax-m3"
    litellm_params:
      model: "ollama_chat/minimax-m3"
      litellm_credential_name: ollama_cloud_credential
  - model_name: "ollama-cloud/kimi-k2.7-code"
    litellm_params:
      model: "ollama_chat/kimi-k2.7-code"
      litellm_credential_name: ollama_cloud_credential

  # OpenAI models — provider caches 1024+ token prefixes automatically;
  # retention + per-model cache key improve hit rate and TTL (default 5–10m → 24h).
  - model_name: "openai/gpt-5.5"
    litellm_params:
      model: "openai/gpt-5.5"
      litellm_credential_name: openai_credential
      prompt_cache_retention: "24h"
      prompt_cache_key: "openai/gpt-5.5"
  - model_name: "openai/gpt-5.4"
    litellm_params:
      model: "openai/gpt-5.4"
      litellm_credential_name: openai_credential
      prompt_cache_retention: "24h"
      prompt_cache_key: "openai/gpt-5.4"
  - model_name: "openai/gpt-5.4-mini"
    litellm_params:
      model: "openai/gpt-5.4-mini"
      litellm_credential_name: openai_credential
      prompt_cache_retention: "24h"
      prompt_cache_key: "openai/gpt-5.4-mini"
  - model_name: "openai/gpt-5.4-nano"
    litellm_params:
      model: "openai/gpt-5.4-nano"
      litellm_credential_name: openai_credential
      prompt_cache_retention: "24h"
      prompt_cache_key: "openai/gpt-5.4-nano"

  # Anthropic models — auto-inject cache_control on system messages (min 2048 tokens for 4.x).
  - model_name: "anthropic/claude-opus-4.8"
    litellm_params:
      model: "anthropic/claude-opus-4-8"
      litellm_credential_name: anthropic_credential
      cache_control_injection_points:
        - location: message
          role: system
  - model_name: "anthropic/claude-sonnet-4.6"
    litellm_params:
      model: "anthropic/claude-sonnet-4-6"
      litellm_credential_name: anthropic_credential
      cache_control_injection_points:
        - location: message
          role: system
  - model_name: "anthropic/claude-fable-5"
    litellm_params:
      model: "anthropic/claude-fable-5"
      litellm_credential_name: anthropic_credential
      cache_control_injection_points:
        - location: message
          role: system

  # Speaches STT/TTS (K8s)
  - model_name: "aether/whisper-large-v3"
    litellm_params:
      model: "openai/Systran/faster-whisper-large-v3"
      litellm_credential_name: speaches_credential
  - model_name: "aether/distil-whisper-large-v3"
    litellm_params:
      model: "openai/Systran/faster-distil-whisper-large-v3"
      litellm_credential_name: speaches_credential
  - model_name: "aether/kokoro-tts"
    litellm_params:
      model: "openai/speaches-ai/Kokoro-82M-v1.0-ONNX"
      litellm_credential_name: speaches_credential

  # Reranker + Embeddings via llama-swap (K8s)
  - model_name: "aether/bge-reranker-v2-m3"
    litellm_params:
      model: "openai/bge-reranker-v2-m3"
      litellm_credential_name: llama_swap_credential
  - model_name: "aether/qwen3-embedding:4b"
    litellm_params:
      model: "openai/qwen3-embedding-4b"
      litellm_credential_name: llama_swap_credential
      encoding_format: "float"
      additional_drop_params: ["dimensions"]
  - model_name: "aether/qwen3-embedding:0.6b"
    litellm_params:
      model: "openai/qwen3-embedding-0.6b"
      litellm_credential_name: llama_swap_credential
      encoding_format: "float"
      additional_drop_params: ["dimensions"]
  # AFFiNE 0.26.3 hardcodes gemini-embedding-001 for embed calls and accepts
  # text-embedding-3-large for the startup capability check (OpenAI provider builtin).
  # AFFiNE always sends dimensions=256; qwen backends ignore it — drop before LiteLLM validation.
  - model_name: "gemini-embedding-001"
    litellm_params:
      model: "openai/qwen3-embedding-0.6b"
      litellm_credential_name: llama_swap_credential
      encoding_format: "float"
      additional_drop_params: ["dimensions"]
  - model_name: "text-embedding-3-large"
    litellm_params:
      model: "openai/qwen3-embedding-0.6b"
      litellm_credential_name: llama_swap_credential
      encoding_format: "float"
      additional_drop_params: ["dimensions"]

  # Xiaomi MiMo models
  - model_name: "xiaomi/mimo-v2.5-pro"
    litellm_params:
      model: "openai/mimo-v2.5-pro"
      litellm_credential_name: xiaomi_credential

  # OpenRouter models
  - model_name: "openrouter/grok-4"
    litellm_params:
      model: "openai/x-ai/grok-4"
      litellm_credential_name: openrouter_credential
  - model_name: "openrouter/gemini-3.1-pro-preview"
    litellm_params:
      model: "openai/google/gemini-3.1-pro-preview"
      litellm_credential_name: openrouter_credential

  # Cursor Composer model aliases via self-hosted composer-api (personal ns).
  # LiteLLM 1.86 also exposes first-class Cursor BYOK routes under /cursor/*;
  # these aliases keep /v1/chat/completions and /v1/responses OpenAI-compatible.
  # The explicit chat-completions flag lets LiteLLM bridge /responses clients to
  # the composer-api /chat/completions endpoint instead of forwarding /responses.
  - model_name: "cursor/composer-2.5"
    litellm_params:
      model: "openai/composer-2.5"
      litellm_credential_name: composer_credential
      use_chat_completions_api: true
  - model_name: "cursor/composer-2.5-fast"
    litellm_params:
      model: "openai/composer-2.5-fast"
      litellm_credential_name: composer_credential
      use_chat_completions_api: true

credential_list:
  - credential_name: llama_swap_credential
    credential_values:
      api_base: http://llama-swap.infra.svc.cluster.local:8080/v1
      api_key: none
    credential_info:
      description: "llama-swap on K8s"
  - credential_name: composer_credential
    credential_values:
      # composer runs in the `personal` ns (outside the infra ambient mesh), so
      # cross-ns cluster DNS is unreachable from here; use the public ingress.
      api_base: https://composer.home.shdr.ch/v1
      api_key: os.environ/CURSOR_API_KEY
    credential_info:
      description: "Cursor Composer (self-hosted)"
  - credential_name: speaches_credential
    credential_values:
      api_base: http://speaches.infra.svc.cluster.local:8000/v1
      api_key: none
    credential_info:
      description: "Speaches STT/TTS on K8s"
  - credential_name: ollama_cloud_credential
    credential_values:
      api_base: https://ollama.com
      api_key: os.environ/OLLAMA_API_KEY
    credential_info:
      description: "Ollama Cloud"
  - credential_name: openai_credential
    credential_values:
      api_key: os.environ/OPENAI_API_KEY
    credential_info:
      description: "OpenAI"
  - credential_name: anthropic_credential
    credential_values:
      api_key: os.environ/ANTHROPIC_API_KEY
    credential_info:
      description: "Anthropic"
  - credential_name: openrouter_credential
    credential_values:
      api_base: https://openrouter.ai/api/v1
      api_key: os.environ/OPENROUTER_API_KEY
    credential_info:
      description: "OpenRouter"
  - credential_name: xiaomi_credential
    credential_values:
      api_base: https://token-plan-sgp.xiaomimimo.com/v1
      api_key: os.environ/XIAOMI_API_KEY
    credential_info:
      description: "Xiaomi MiMo"

litellm_settings:
  drop_params: true
  turn_off_message_logging: false
  set_verbose: true
  json_logs: true
  request_timeout: 600

general_settings:
  store_prompts_in_spend_logs: true

mcp_servers:
  time:
    url: "http://localhost:8003/mcp"
  firecrawl:
    url: "http://firecrawl.infra.svc.cluster.local:3007/mcp"
  alpha_vantage:
    url: "https://mcp.alphavantage.co/mcp?apikey=${alphavantage_api_key}"
  # coingecko:
  #   url: "http://localhost:8002/"
  finviz:
    url: "http://localhost:8000/mcp"
%{ if google_maps_enabled ~}
  google_maps:
    url: "http://localhost:8004/mcp"
%{ endif ~}
